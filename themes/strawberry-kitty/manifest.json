  "layout": {
    "chrome-style": "floating",
    "input-style": "floating",
    "bubble-style": "pill",
    "header-style": "default",
    "statusbar-style": "default"
  },
  "effects": {
    "particles": "dust",
    "particle-count": 24,
    "particle-speed": 0.3,
    "particle-drift": 0.3,
    "particle-size-range": [
      3,
      8
    ],
    "vignette": 0.14,
    "noise": 0
  },
  "mascot": {
    "idle": "theme-asset://strawberry-kitty/assets/mascot-idle.svg",
    "welcome": "theme-asset://strawberry-kitty/assets/mascot-welcome.svg",
    "shocked": "theme-asset://strawberry-kitty/assets/mascot-shocked.svg",
    "dizzy": "theme-asset://strawberry-kitty/assets/mascot-dizzy.svg"
  },
  "custom_css": "::selection { background: rgba(217,78,107,0.32); color: #FFFFFF; }\nbody::after { content: ''; position: fixed; inset: 0; background-image: url('theme-asset://strawberry-kitty/assets/pattern.svg'); background-size: 40px 40px; background-repeat: repeat; opacity: 0.06; pointer-events: none; z-index: 0; }"
}