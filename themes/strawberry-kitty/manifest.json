{
  "name": "Strawberry Kitty",
  "slug": "strawberry-kitty",
  "dark": false,
  "author": "claude",
  "created": "2026-04-12",
  "description": "Lighter pink Hello Kitty x strawberry shortcake — pastel rose canvas, floating chrome, pill bubbles, dust drift over a sweet berry wallpaper.",
  "tokens": {
    "canvas": "#F8D7DE",
    "panel": "#FCE4E9",
    "inset": "#FFF1F3",
    "well": "#EFBCC6",
    "accent": "#D94E6B",
    "on-accent": "#FFFFFF",
    "fg": "#3A1420",
    "fg-2": "#5C2235",
    "fg-dim": "#7E3850",
    "fg-muted": "#A3627A",
    "fg-faint": "#C9959F",
    "edge": "#E09AA8",
    "edge-dim": "#E09AA880",
    "scrollbar-thumb": "#D94E6B",
    "scrollbar-hover": "#B33952"
  },
  "shape": {
    "radius": "18px",
    "radius-sm": "16px",
    "radius-md": "26px",
    "radius-lg": "32px",
    "radius-full": "9999px"
  },
  "font": {
    "family": "'Comfortaa', 'Cascadia Mono', monospace",
    "google-font-url": "https://fonts.googleapis.com/css2?family=Comfortaa:wght@400;500;600;700&display=swap"
  },
  "background": {
    "type": "image",
    "value": "theme-asset://strawberry-kitty/assets/wallpaper.png",
    "terminal-value": "theme-asset://strawberry-kitty/assets/wallpaper-terminal.webp",
    "opacity": 1,
    "panels-blur": 4,
    "panels-opacity": 0.3,
    "bubble-blur": 13,
    "bubble-opacity": 0.68,
    "pattern": "theme-asset://strawberry-kitty/assets/pattern.svg",
    "pattern-opacity": 0.06
