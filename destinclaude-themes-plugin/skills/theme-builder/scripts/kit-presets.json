{
  "_comment": "Preset cards rendered as clickable options in the Kit refinement page. Each column's `presets` array is rendered by the browser at runtime — Claude only sets the `current` values when writing screen.html. Keep swatch/sample data self-contained so the page works without extra asset fetches.",

  "palette": [
    {
      "id": "warm-cozy",
      "name": "Warm Cozy",
      "blurb": "Amber on deep brown — autumn, tavern, firelit",
      "swatches": ["#1A100A", "#231509", "#2D1C0C", "#E8A94E", "#F5E6D0"],
      "dark": true
    },
    {
      "id": "neon-cyber",
      "name": "Neon Cyber",
      "blurb": "Hot magenta on near-black blue — cyberpunk, Y2K",
      "swatches": ["#08080F", "#11111A", "#181825", "#FF2E88", "#EDEBFF"],
      "dark": true
    },
    {
      "id": "dark-noir",
      "name": "Dark Noir",
      "blurb": "Crimson on near-black — noir, grim, ritualistic",
      "swatches": ["#0B0A0A", "#141212", "#1C1919", "#D94444", "#E8DDDD"],
      "dark": true
    },
    {
      "id": "earth-forest",
      "name": "Earth Forest",
      "blurb": "Moss green on deep earth — cottagecore, herbalist",
      "swatches": ["#0F130C", "#171C13", "#1E2619", "#7BA85A", "#E4E8D9"],
      "dark": true
    },
    {
      "id": "midnight-space",
      "name": "Midnight Space",
      "blurb": "Cyan on deep indigo — space, midnight, ocean",
