  "effects": {
    "_comment": "Multi-pick rather than single-pick. Particles are mutually exclusive (one type); vignette/noise/scanlines are independent toggles with intensity.",
    "particles": [
      { "id": "none", "name": "None", "blurb": "No floating particles" },
      { "id": "dust", "name": "Dust", "blurb": "Slow drifting motes — cozy, atmospheric" },
      { "id": "rain", "name": "Rain", "blurb": "Downward streaks — moody, noir" },
      { "id": "snow", "name": "Snow", "blurb": "Gentle falling flakes — winter, calm" },
      { "id": "ember", "name": "Ember", "blurb": "Rising sparks — fire, warmth, danger" },
      { "id": "custom", "name": "Custom Shape", "blurb": "Describe a shape — Claude draws the SVG" }
    ],
    "overlays": [
      { "id": "vignette", "name": "Vignette", "blurb": "Darkened corners — cinematic framing", "default-intensity": 0.2 },
      { "id": "noise", "name": "Noise", "blurb": "Subtle grain — film, paper, texture", "default-intensity": 0.03 },
      { "id": "scanlines", "name": "Scan Lines", "blurb": "Horizontal CRT lines — retro, terminal", "default-intensity": 1 }
    ]
