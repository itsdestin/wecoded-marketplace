      "dark": true
    },
    {
      "id": "pastel-soft",
      "name": "Pastel Soft",
      "blurb": "Soft lavender on cream — kawaii, paper, spring",
      "swatches": ["#FAF5F2", "#F2EAE8", "#EBDFDE", "#9B7AC4", "#3D2F4A"],
      "dark": false
    }
  ],

  "chrome": [
    {
      "id": "default",
      "name": "Classic",
      "blurb": "Standard top header, bottom input — the default app layout",
      "layout": { "chrome-style": "default", "input-style": "default", "header-style": "default", "statusbar-style": "default" }
    },
    {
      "id": "floating",
      "name": "Floating",
      "blurb": "Header, input, and status bars float as detached rounded cards",
      "layout": { "chrome-style": "floating", "input-style": "floating", "header-style": "default", "statusbar-style": "default" }
    },
    {
      "id": "minimal",
      "name": "Minimal",
      "blurb": "Header hidden, thin status bar, input as a single line",
      "layout": { "chrome-style": "default", "input-style": "minimal", "header-style": "minimal", "statusbar-style": "minimal" }
    },
    {
      "id": "terminal",
      "name": "Terminal",
      "blurb": "Monospace-forward, input styled as a shell prompt",
      "layout": { "chrome-style": "default", "input-style": "terminal", "header-style": "default", "statusbar-style": "default" }
    }
  ],

  "bubble": [
    {
      "id": "default",
      "name": "Rounded",
      "blurb": "Standard rounded rectangles — safe default",
      "value": "default"
    },
    {
      "id": "pill",
      "name": "Pill",
