{
  "manifest_version": 3,
  "name": "gmessages Cookie Refresh",
  "version": "1.0",
  "description": "Keeps Google Messages MCP server authenticated by refreshing cookies",
  "permissions": ["cookies", "alarms"],
  "host_permissions": [
    "https://*.google.com/*",
    "http://127.0.0.1:9595/*"
  ],
  "background": {
    "service_worker": "background.js"
  },
  "icons": {}
}
